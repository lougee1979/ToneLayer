<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Do not back up API keys, consent choices, or private rewrite settings. -->
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Do not transfer API keys, consent choices, or private rewrite settings. -->
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
